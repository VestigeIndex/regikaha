{
  "name": "regikaha",
  "version": "0.1.0",
  "private": true,
  "description": "RegiKaha — Marketplace español de profesionales verificados para reformas, construcción y servicios técnicos.",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/analyze-cost.mjs",
    "cf:deploy:regikaha": "node scripts/deploy-regikaha.mjs",
    "cf:deploy:regikaha:worker": "wrangler pages functions build functions --outdir .wrangler/functions-build",
    "cf:deploy:regikaha:pages": "wrangler pages deploy out --project-name regikaha --branch main",
    "cf:d1:migrate:regikaha": "wrangler d1 migrations apply regikaha-db --remote",
    "cf:d1:backup:regikaha": "wrangler d1 export regikaha-db --remote --output regikaha-d1-backup.sql",
    "cf:r2:check": "wrangler r2 bucket info regikaha-media --jurisdiction eu",
    "analyze:bundle": "node scripts/analyze-bundle.mjs",
    "analyze:workers": "node scripts/analyze-workers.mjs",
    "analyze:cost": "node scripts/analyze-cost.mjs",
    "geo:validate": "node scripts/validate-geodata.mjs",
    "geo:index": "node scripts/build-geo-index.mjs",
    "geo:sql": "node scripts/import-geodata.mjs"
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "clsx": "^2.1.1",
    "flag-icons": "^7.5.0",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
    ,"wrangler": "^4.103.0"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
